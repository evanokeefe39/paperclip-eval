# Provider API keys — add the ones you use
DEEPSEEK_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
NVIDIA_NIM_API_KEY=
MINIMAX_API_KEY=

# Web search/fetch (Exa API — used by web-search extension)
EXA_API_KEY=

# Bridge defaults (override per-agent via docker-compose env if needed)
BRIDGE_PORT=8080
BRIDGE_TIMEOUT_MS=120000
LOG_LEVEL=info

# Escalation extension — enables agent-to-human escalation via Paperclip issues
# All five required for the escalate tool to register
PAPERCLIP_API_URL=http://paperclip:3100
PAPERCLIP_ADMIN_EMAIL=admin@eval.local
PAPERCLIP_ADMIN_PASS=eval-admin-2026
PAPERCLIP_COMPANY_ID=
CEO_AGENT_ID=
RESEARCHER_AGENT_ID=
