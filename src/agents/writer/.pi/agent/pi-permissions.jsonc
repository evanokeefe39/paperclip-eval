// Writer Agent Permission Policy
// Role: content creation, formatting, style checking, document production.
// Full executor access plus style/lint tools and document writing.
{
  "defaultPolicy": {
    "tools": "deny",
    "bash": "allow",
    "mcp": "deny",
    "skills": "allow",
    "special": "allow"
  },

  "tools": {
    "*": "deny",

    // Built-in tools — full executor access
    "read": "allow",
    "write": "allow",
    "edit": "allow",
    "grep": "allow",
    "find": "allow",
    "ls": "allow",
    "bash": "allow",

    // Web tools (for reference/fact-checking)
    "web_search": "allow",
    "web_fetch": "allow",

    // Artifacts — full access
    "write_artifact": "allow",
    "read_artifact": "allow",
    "list_artifacts": "allow",
    "get_template": "allow",

    // Workproduct — writer kinds (report, guide, article, marketing_copy, newsletter)
    "record_report": "allow",
    "record_guide": "allow",
    "record_article": "allow",
    "record_marketing_copy": "allow",
    "record_newsletter": "allow",
    "query_content": "allow",
    "get_content": "allow",

    // DuckDB (query data for reports)
    "duckdb_query": "allow",
    "duckdb_import": "allow",

    // Logging
    "log_event": "allow",
    "get_log": "allow",
    "get_trace_id": "allow",

    // Escalation
    "escalate": "allow",

    // Paperclip — executor subset + document writing
    "paperclip_me": "allow",
    "paperclip_inbox": "allow",
    "paperclip_list_*": "allow",
    "paperclip_get_*": "allow",
    "paperclip_checkout_issue": "allow",
    "paperclip_release_issue": "allow",
    "paperclip_update_issue": "allow",
    "paperclip_add_comment": "allow",
    "paperclip_upsert_document": "allow",

    // Paperclip — denied
    "paperclip_create_issue": "deny",
    "paperclip_invoke_agent": "deny",
    "paperclip_suggest_tasks": "deny",
    "paperclip_ask_user_questions": "deny",
    "paperclip_request_confirmation": "deny",
    "paperclip_create_approval": "deny",
    "paperclip_approval_decision": "deny",
    "paperclip_restore_document_revision": "deny",
    "paperclip_control_workspace_services": "deny",
    "paperclip_wait_for_workspace_service": "deny",
    "paperclip_get_workspace_runtime": "deny",
    "paperclip_api_request": "deny",

    // Scraping — not writer's job
    "scrape_static": "deny",
    "scrape_stealth": "deny",
    "scrape_browser": "deny",
    "scrape_apify": "deny",

    // CEO-only
    "triage_task": "deny",
    "advance_to_delegation": "deny"
  },

  "bash": {
    "*": "allow"
  }
}
