// CEO Agent Permission Policy
// Role: strategic coordination only — no code execution, no file writing, no research work.
// Delegation via Paperclip issues, not subagents or direct execution.
{
  "defaultPolicy": {
    "tools": "deny",
    "bash": "deny",
    "mcp": "deny",
    "skills": "allow",
    "special": "allow"
  },

  "tools": {
    // Default: deny everything not explicitly allowed
    "*": "deny",

    // Read-only built-ins
    "read": "allow",
    "grep": "allow",
    "find": "allow",
    "ls": "allow",

    // Triage workflow (phase state machine)
    "triage_task": "allow",
    "advance_to_delegation": "allow",

    // Web search (phase-gated by triage-workflow.ts)
    "web_search": "allow",

    // Escalation to human
    "escalate": "allow",

    // Artifacts (read-only)
    "read_artifact": "allow",
    "list_artifacts": "allow",

    // Logging / observability
    "log_event": "allow",
    "get_log": "allow",
    "get_trace_id": "allow",

    // Paperclip coordination — read/list operations
    "paperclip_me": "allow",
    "paperclip_inbox": "allow",
    "paperclip_list_*": "allow",
    "paperclip_get_*": "allow",

    // Paperclip coordination — issue management
    "paperclip_create_issue": "allow",
    "paperclip_update_issue": "allow",
    "paperclip_add_comment": "allow",
    "paperclip_invoke_agent": "allow",

    // Paperclip coordination — interactions
    "paperclip_suggest_tasks": "allow",
    "paperclip_ask_user_questions": "allow",
    "paperclip_request_confirmation": "allow",

    // Paperclip coordination — approvals
    "paperclip_create_approval": "allow",
    "paperclip_approval_decision": "allow",
    "paperclip_link_issue_approval": "allow",
    "paperclip_unlink_issue_approval": "allow",

    // --- Explicit denies (override wildcards above) ---

    // Execution tools — CEO must not do work
    "paperclip_checkout_issue": "deny",
    "paperclip_release_issue": "deny",
    "paperclip_upsert_document": "deny",
    "paperclip_restore_document_revision": "deny",
    "paperclip_control_workspace_services": "deny",
    "paperclip_wait_for_workspace_service": "deny",
    "paperclip_get_workspace_runtime": "deny",
    "paperclip_api_request": "deny",

    // Write tools — CEO is read-only
    "write": "deny",
    "edit": "deny",
    "bash": "deny",
    "write_artifact": "deny",
    "get_template": "deny"
  },

  "bash": {
    "*": "deny"
  }
}
