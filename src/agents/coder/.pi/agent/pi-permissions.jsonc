// Default executor agent permission policy
// Role: executor — works on assigned issues, reads/writes files, uses bash.
// Customize per agent as role-specific tools are added.
{
  "defaultPolicy": {
    "tools": "deny",
    "bash": "allow",
    "mcp": "deny",
    "skills": "allow",
    "special": "allow"
  },

  "tools": {
    "*": "deny",

    // Built-in tools — full executor access
    "read": "allow",
    "write": "allow",
    "edit": "allow",
    "grep": "allow",
    "find": "allow",
    "ls": "allow",
    "bash": "allow",

    // Artifacts — full access
    "write_artifact": "allow",
    "read_artifact": "allow",
    "list_artifacts": "allow",
    "get_template": "allow",

    // Escalation
    "escalate": "allow",

    // Web tools
    "web_search": "allow",
    "web_fetch": "allow",

    // DuckDB
    "duckdb_query": "allow",
    "duckdb_import": "allow",

    // Findings
    "record_finding": "allow",
    "list_findings": "allow",
    "export_findings": "allow",

    // Paperclip — executor subset
    "paperclip_me": "allow",
    "paperclip_inbox": "allow",
    "paperclip_list_*": "allow",
    "paperclip_get_*": "allow",
    "paperclip_checkout_issue": "allow",
    "paperclip_release_issue": "allow",
    "paperclip_update_issue": "allow",
    "paperclip_add_comment": "allow",

    // Paperclip — denied (coordination tools)
    "paperclip_create_issue": "deny",
    "paperclip_invoke_agent": "deny",
    "paperclip_suggest_tasks": "deny",
    "paperclip_ask_user_questions": "deny",
    "paperclip_request_confirmation": "deny",
    "paperclip_create_approval": "deny",
    "paperclip_approval_decision": "deny",
    "paperclip_upsert_document": "deny",
    "paperclip_restore_document_revision": "deny",
    "paperclip_control_workspace_services": "deny",
    "paperclip_wait_for_workspace_service": "deny",
    "paperclip_get_workspace_runtime": "deny",
    "paperclip_api_request": "deny",

    // CEO-only
    "triage_task": "deny",
    "advance_to_delegation": "deny"
  },

  "bash": {
    "*": "allow"
  }
}
