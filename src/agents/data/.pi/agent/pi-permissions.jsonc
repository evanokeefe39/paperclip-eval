// Data Agent Permission Policy
// Role: data collection, scraping (including browser), database queries, structured extraction.
// Full executor access plus heavy scraping tools and DuckDB.
{
  "defaultPolicy": {
    "tools": "deny",
    "bash": "allow",
    "mcp": "deny",
    "skills": "allow",
    "special": "allow"
  },

  "tools": {
    "*": "deny",

    // Built-in tools — full executor access
    "read": "allow",
    "write": "allow",
    "edit": "allow",
    "grep": "allow",
    "find": "allow",
    "ls": "allow",
    "bash": "allow",

    // Scraping tools — full tier access including browser
    "scrape_static": "allow",
    "scrape_stealth": "allow",
    "scrape_browser": "allow",
    "scrape_apify": "allow",
    "list_actors": "allow",
    "scrape_status": "allow",

    // Web tools
    "web_search": "allow",
    "web_fetch": "allow",

    // DuckDB — primary data tool
    "duckdb_query": "allow",
    "duckdb_import": "allow",

    // Artifacts — full access
    "write_artifact": "allow",
    "read_artifact": "allow",
    "list_artifacts": "allow",
    "get_template": "allow",

    // Workproduct — data kinds (dataset_ref, query_result, metric, chart)
    "record_dataset_ref": "allow",
    "record_query_result": "allow",
    "record_metric": "allow",
    "record_chart": "allow",
    "query_data_products": "allow",
    "get_data_product": "allow",

    // Escalation
    "escalate": "allow",

    // Paperclip — executor subset
    "paperclip_me": "allow",
    "paperclip_inbox": "allow",
    "paperclip_list_*": "allow",
    "paperclip_get_*": "allow",
    "paperclip_checkout_issue": "allow",
    "paperclip_release_issue": "allow",
    "paperclip_update_issue": "allow",
    "paperclip_add_comment": "allow",

    // Paperclip — denied
    "paperclip_create_issue": "deny",
    "paperclip_invoke_agent": "deny",
    "paperclip_suggest_tasks": "deny",
    "paperclip_ask_user_questions": "deny",
    "paperclip_request_confirmation": "deny",
    "paperclip_create_approval": "deny",
    "paperclip_approval_decision": "deny",
    "paperclip_upsert_document": "deny",
    "paperclip_restore_document_revision": "deny",
    "paperclip_control_workspace_services": "deny",
    "paperclip_wait_for_workspace_service": "deny",
    "paperclip_get_workspace_runtime": "deny",
    "paperclip_api_request": "deny",

    // CEO-only
    "triage_task": "deny",
    "advance_to_delegation": "deny"
  },

  "bash": {
    "*": "allow"
  }
}
