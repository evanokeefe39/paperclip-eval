{
  "packages": [
    "npm:shitty-extensions",
    "npm:@ifi/pi-extension-subagents",
    "npm:pi-otel"
  ],
  "terminal": {
    "showTerminalProgress": true
  },
  "steeringMode": "all",
  "followUpMode": "all",
  "quietStartup": true,
  "theme": "dark",
  "defaultProvider": "deepseek",
  "defaultModel": "deepseek-chat",
  "defaultThinkingLevel": "high",
  "compaction": {
    "enabled": false
  },
  "otel": {
    "enabled": true,
    "endpoint": "http://dashboard:18889",
    "protocol": "grpc",
    "serviceName": "qa-agent",
    "captureContent": "metadata_only",
    "signals": { "traces": true, "metrics": false, "logs": true }
  }
}
